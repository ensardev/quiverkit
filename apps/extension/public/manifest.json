{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "0.1.0",
  "description": "__MSG_appDescription__",
  "default_locale": "en",
  "minimum_chrome_version": "114",
  "icons": {
    "32": "icons/32.png",
    "128": "icons/128.png"
  },
  "permissions": ["contextMenus", "sidePanel", "storage"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "action": {
    "default_title": "QuiverKit"
  }
}
