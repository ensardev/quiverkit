{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "QuiverKit",
  "version": "0.1.0",
  "identifier": "dev.quiverkit.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev:vite",
    "beforeBuildCommand": "npm run build:vite"
  },
  "app": {
    "windows": [
      {
        "title": "QuiverKit",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "decorations": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "tooltip": "QuiverKit"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["jwt"],
        "name": "JSON Web Token",
        "description": "JSON Web Token",
        "role": "Viewer"
      },
      {
        "ext": ["json"],
        "name": "JSON Document",
        "description": "JSON data file",
        "role": "Editor"
      },
      {
        "ext": ["pem", "crt", "cert", "csr"],
        "name": "Certificate file",
        "description": "Digital certificate or key file",
        "role": "Viewer"
      }
    ]
  }
}
